rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Okuma: herkese açık koleksiyonlar
    match /projects/{id} { allow read: if true; allow write: if request.auth != null; }
    match /listings/{id} { allow read: if true; allow write: if request.auth != null; }
    match /events/{id} { allow read: if true; allow write: if request.auth != null; }
    match /blogPosts/{id} { allow read: if true; allow write: if request.auth != null; }
    match /sectors/{id} { allow read: if true; allow write: if request.auth != null; }
    match /donors/{id} { allow read: if true; allow write: if request.auth != null; }

    // Yalnızca giriş yapmış kullanıcı
    match /rsvps/{id} { allow read, write: if request.auth != null; }
    match /documents/{id} { allow read, write: if request.auth != null; }
    match /subscribers/{id} { allow read, write: if request.auth != null; }
    match /campaigns/{id} { allow read, write: if request.auth != null; }
    match /stakeholders/{id} { allow read, write: if request.auth != null; }
    match /trainingVideos/{id} { allow read: if true; allow write: if request.auth != null; }
    match /ownershipRequests/{id} { allow read, write: if request.auth != null; }
    match /expertProfiles/{id} { allow read: if true; allow write: if request.auth != null; }
  }
}
